<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        The app's main theme.

        Parent "Theme.MaterialComponents.DayNight.NoActionBar":
          - MaterialComponents: enables Material Design widgets (MaterialButton, etc.)
          - DayNight: automatically switches light/dark based on the system setting
          - NoActionBar: we manage our own Toolbar in activity_main.xml rather than
            using the system-provided ActionBar. This gives more control.
    -->
    <style name="Theme.TyrePressure" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colour: shown in the toolbar, buttons, etc. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary accent colour -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar colour (the bar at the very top of the screen) -->
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>
</resources>
